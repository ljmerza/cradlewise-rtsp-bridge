# Cradlewise account credentials (same account as the mobile app).
CRADLEWISE_EMAIL=
CRADLEWISE_PASSWORD=

# Which crib to bridge: match a cradle_id or baby_name. Empty = first cradle.
CRADLEWISE_CRADLE=

# Device NAME used to provision a stable, registered device_id (the videoRoom
# API rejects unregistered ids). A Cradlewise account has a device-slot limit;
# if a brand-new name fails to provision (HTTP 422 DEVICE_ASSIGNMENT_FAILED),
# set this to an already-registered device-name on the account.
CRADLEWISE_DEVICE_NAME=cradlewise-rtsp-bridge

# Include the crib's audio track in the published stream (1/0).
CRADLEWISE_AUDIO=1

# Local RTSP target inside the container (must match the mediamtx path; the
# default mediamtx path is "cradlewise"). Usually leave unset.
# RTSP_URL=rtsp://127.0.0.1:8554/cradlewise

LOG_LEVEL=INFO
