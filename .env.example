# Cradlewise account credentials (same account as the mobile app). REQUIRED —
# these are the only vars you must set. The bridge discovers every crib on the
# account and publishes each to rtsp://<host>:8554/cradlewise_<baby_name>.
CRADLEWISE_EMAIL=
CRADLEWISE_PASSWORD=

# ── Optional (sensible defaults) ────────────────────────────────────────────
# Device NAME used to provision a stable, registered device_id (the videoRoom
# API rejects unregistered ids). A Cradlewise account has a device-slot limit; if
# provisioning fails with HTTP 422 DEVICE_ASSIGNMENT_FAILED, free a slot in the
# app (remove an unused device) or set this to an already-registered name.
# CRADLEWISE_DEVICE_NAME=cradlewise-rtsp-bridge

# Base RTSP target inside the container; each crib is published to
# "<RTSP_BASE>/cradlewise_<baby_name>". Usually leave unset.
# RTSP_BASE=rtsp://127.0.0.1:8554

# Include each crib's audio track in the published stream (1/0).
# CRADLEWISE_AUDIO=1

# LOG_LEVEL=INFO
